# Central pinned refs for in-lab player builds (Plan A).
#
# One source of truth so every Nim player compiles against the SAME crewrift game
# version. Sourced by tools/build_player.sh and passed to the Dockerfiles as
# --build-arg. See docs/designs/in-lab-builds.md.

# The crewrift game commit the Nim players (notsus, suspectra) compile against.
#
# CORRECTNESS: this MUST match the game version running in the league you target,
# or built players can skew from live behavior (the same version-skew that breaks
# expand_replay — see docs/crewrift-replays.md §B). Current value is the lab's
# validated ref (crewrift d9f6b30 / v0.1.40).
# TODO: reconcile against the league's live game version before submitting players.
# (Partly confirmed 2026-06-09: an expand_replay built at d9f6b30 expands current
# Observatory/league replays fully — so d9f6b30's sim matches the live game upload.
# Also used by tools/build_expand_replay.sh as the default replay-reader build.)
CREWRIFT_REF=d9f6b30

# crewborg (Python) is built against the LOCAL players SDK checkout
# (~/coding/players — the lab's SDK source of truth, kept clean/pinned), staged
# into the build context by build_player.sh. There is no SDK build-arg today; if
# the players repo ever becomes a public pinned pip target, crewborg's Dockerfile
# can switch to `pip install "players @ git+...@<ref>"` and this file would gain a
# PLAYERS_SDK_REF.
