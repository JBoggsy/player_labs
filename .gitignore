analysis/
# Scratch/downloaded-coworld dir only (top-level). Do NOT ignore a player
# package's source `coworld/` subdir (e.g. agricogla/farmhand/coworld,
# crewborg/coworld) — those hold the bridge + Dockerfile and must be tracked.
/coworld/
*.bitreplay
*.replay.json.z
*.sqlite

# Per-experiment scratch logs
*.log

# Local secrets / env
.env
.env.*

# In-lab expand_replay build: fetched game source + built binaries
crewrift_lab/.cache/
crewrift_lab/tools/bin/
.superpowers/

# positioning_viz debug screenshots + playwright artifacts
posviz_*.png
.playwright-mcp/
.claude/worktrees/
crewrift_lab/.claude/worktrees/
