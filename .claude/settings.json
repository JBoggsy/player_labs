{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/crewrift_lab/tools/rotate_lessons.sh\"",
            "timeout": 15,
            "statusMessage": "Rotating Crewrift tentative-lessons buffer"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/cue_n_woo_lab/tools/rotate_lessons.sh\"",
            "timeout": 15,
            "statusMessage": "Rotating Cue-n-Woo tentative-lessons buffer"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/heartleaf_lab/tools/rotate_lessons.sh\"",
            "timeout": 15,
            "statusMessage": "Rotating Heartleaf tentative-lessons buffer"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/ctf_lab/tools/rotate_lessons.sh\"",
            "timeout": 15,
            "statusMessage": "Rotating CTF tentative-lessons buffer"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/vanilla_wow_lab/tools/rotate_lessons.sh\"",
            "timeout": 15,
            "statusMessage": "Rotating Vanilla WoW tentative-lessons buffer"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/tools/lessons_stop_nudge.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
