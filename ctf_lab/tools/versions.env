# Central pinned refs for in-lab CTF player builds.
#
# One source of truth so builds are reproducible. Sourced by tools/build_player.sh.

# The shared player SDK that beacon (Python) builds against — installed from the
# coworld-tools monorepo's GitHub source tarball (the `players/` subdirectory). Kept
# in sync with the root pyproject.toml [tool.uv.sources] tarball SHA so local `uv run`
# and the built image run the SAME SDK (SpriteV1 bridge included). To bump: set the SHA
# here + in pyproject.toml and `uv lock`. A literal `main` is a Docker cache trap (the
# pip layer caches on the URL string), so build_player.sh resolves `main` via ls-remote.
# Pinned to e8921a6 (2026-07-06): first coworld-tools main with the SpriteV1 bridge
# (players.player_sdk.sprite_bridge) that beacon/cady build on.
PLAYERS_SDK_REF=e8921a6b18484030d8704277e4c52d3aae5c8917

# The coworld-ctf game commit beacon's baked nav grid + geometry constants were derived
# from (tools/bake_map.py, config.py). DELIBERATELY PINNED — it must match the game
# version the LEAGUE actually runs, not `main`. If a fresh league replay stops matching
# beacon's geometry (or expand_replay hash-fails), the league redeployed: re-derive the
# arena and bump this. Current value (761c098) is coworld-ctf HEAD as of 2026-07-10.
CTF_REF=761c098
